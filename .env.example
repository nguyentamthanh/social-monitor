# Database (required)
NEON_DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# NextAuth (required)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-random-32-char-secret-here

# Vercel Blob (required in production; optional locally)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxx

# YouTube Data API v3 (for video & music copyright scan)
YOUTUBE_API_KEY=

# Google Programmable Search (for web & image copyright scan)
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

# Facebook (optional, limited)
FACEBOOK_ACCESS_TOKEN=

# TikTok (optional, limited)
TIKTOK_ACCESS_TOKEN=
